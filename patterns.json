      "provider": "Generic",
      "category": "Generic / Crypto",
      "name": "Base64 string",
      "regex": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$",
      "strategy": "encoding",
      "refs": [
        "https://datatracker.ietf.org/doc/html/rfc4648#section-4"
      ],
      "notes": "Format validator, not a secret. Standard Base64 alphabet with padding. Anchored."
