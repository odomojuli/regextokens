      "provider": "Twitter / X",
      "category": "Social",
      "name": "OAuth 1.0a access token",
      "regex": "\\b[1-9][0-9]+-[0-9A-Za-z]{40}\\b",
      "strategy": "structure",
      "refs": [
        "https://developer.twitter.com/en/docs/authentication/oauth-1-0a"
      ],
      "notes": "<numeric user id>-<40 alnum>. Structural; pair with a 'twitter' keyword to cut noise."
    },
    {
      "id": "twitter-username",
      "provider": "Twitter / X",
      "category": "Social",
      "name": "Username / handle",
      "regex": "(?:^|[^@\\w])@(\\w{1,15})\\b",
      "strategy": "identifier",
      "refs": [
        "https://github.com/twitter/twitter-text/blob/master/rb/lib/twitter-text/regex.rb"
      ],
      "notes": "Public handle, not a secret. 1-15 word chars, not preceded by @ or word char."
    },
    {
      "id": "facebook-access-token",
      "provider": "Facebook",
      "category": "Social",
