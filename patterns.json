      "strategy": "keyword",
      "refs": [
        "https://docs.aws.amazon.com/IAM/latest/UserGuide/reference_identifiers.html"
      ],
      "notes": "40-char base64 body has no fixed prefix and is low entropy. Gate on an 'aws' keyword or it matches almost any 40-char token."
