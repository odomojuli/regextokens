      "strategy": "prefix",
      "refs": [
        "https://developers.facebook.com/docs/facebook-login/guides/access-tokens"
      ],
      "notes": "Graph API tokens begin EAA. The old fixed 'EAACEdEose0cBA' app prefix is obsolete."
    },
    {
      "id": "instagram-access-token",
